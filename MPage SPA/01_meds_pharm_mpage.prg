DROP PROGRAM 01_meds_pharm_mpage:group1 GO
CREATE PROGRAM 01_meds_pharm_mpage:group1
PROMPT "Output to File/Printer/MINE" = "MINE", "PatientID" = 0, "EncntrID" = 0
WITH OUTDEV, pid, eid

SET _memory_reply_string = BUILD2(
    ~<!DOCTYPE html>~,
    ~<html><head>~,
    ~<meta charset='utf-8'/>~,
    ~<meta name='discern' content='XMLCCLREQUEST,APPLINK,CCLLINK'/>~,
    ~<title>Pharmacy SPA Prototype</title>~,
    ~<style>~,
    ~  * { box-sizing: border-box; }~,
    ~  body { margin: 0; min-height: 100vh; font-family: Segoe UI, Arial, sans-serif; background: #f4f7fa; color: #1c2733; display: flex; flex-direction: column; }~,
    ~  .nav-bar { display: flex; gap: 4px; padding: 10px 12px 0; background: linear-gradient(135deg, #0c4663 0%, #155e75 100%); }~,
