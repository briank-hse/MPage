    ~function buildSearchSidebarHtml(state, filtered) {~,
    ~  if (!filtered.length) { return '<div class="search-empty">No documents match the current filters.</div>'; }~,
    ~  var html = [];~,
    ~  for (var i = 0; i < filtered.length; i++) {~,
    ~    var result = filtered[i];~,
    ~    var active = result.result_index === state.selectedResultIndex ? ' active' : '';~,
    ~    var previewText = getSearchPreviewText(result.doc_text || '');~,
    ~    var flags = [];~,
    ~    if (result.high_risk_labels) { var labels = String(result.high_risk_labels).split(','); for (var h = 0; h < labels.length; h++) { if (labels[h]) { flags.push('<span class="hr-flag">' + escapeHtml(labels[h]) + '</span>'); } } }~,
    ~    html.push('<div class="doc-item' + active + '" onclick="selectSearchResult(' + result.result_index + ')"><div class="doc-meta">' + escapeHtml(result.event_dt_tm || '') + ' | ' + escapeHtml(result.authored_by || '') + '</div>' +~,
    ~      '<div class="doc-title"><span class="type-badge">' + escapeHtml(result.source_type || result.category || 'DOC') + '</span><span class="raw-title">' + highlightText(result.title || '', state.searchTerm) + '</span></div>' +~,
    ~      (flags.length ? '<div class="nav-flags">' + flags.join('') + '</div>' : '') + '<div class="doc-preview">' + highlightText(previewText.substring(0, 260), state.searchTerm) + '</div></div>');~,
    ~  }~,
    ~  return html.join('');~,
