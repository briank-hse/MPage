    ~function buildSearchViewerHtml(state, filtered) {~,
    ~  if (!filtered.length) { return '<div class="search-empty">No chart documents match the current filters.</div>'; }~,
    ~  if (!Number(state.selectedResultIndex || 0)) { return '<div class="search-empty">Select a document or type to search.</div>'; }~,
    ~  var current = null;~,
    ~  for (var i = 0; i < filtered.length; i++) { if (filtered[i].result_index === state.selectedResultIndex) { current = filtered[i]; break; } }~,
    ~  if (!current) { return '<div class="search-empty">Select a document or type to search.</div>'; }~,
    ~  var flags = [];~,
    ~  if (current.high_risk_labels) { var labels = String(current.high_risk_labels).split(','); for (var h = 0; h < labels.length; h++) { if (labels[h]) { flags.push('<span class="hr-flag">' + escapeHtml(labels[h]) + '</span>'); } } }~,
    ~  return '<div class="search-doc-header"><h3 class="search-doc-title">' + escapeHtml(current.title || '') + '</h3><div class="search-doc-meta"><span class="type-badge">' + escapeHtml(current.source_type || current.category || 'DOC') + '</span>' +~,
    ~    '<b>Date/Time:</b> ' + escapeHtml(current.event_dt_tm || '') + ' &nbsp; <b>Author:</b> ' + escapeHtml(current.authored_by || '') + (flags.length ? ' &nbsp; ' + flags.join('') : '') + '</div></div>' +~,
    ~    '<div class="search-doc-body">' + highlightSearchDocHtml(current.doc_text || '', state.searchTerm) + '</div>';~,
    ~}~,
    ~function highlightActiveSearchMatch() {~,
    ~  var state = SPA_STATE.search; var viewer = document.getElementById('search-document-viewer'); if (!state || !viewer) { return; }~,
    ~  var matches = viewer.querySelectorAll('mark');~,
    ~  for (var i = 0; i < matches.length; i++) { matches[i].classList.remove('active-match'); }~,
    ~  if (!matches.length) { return; }~,
    ~  if (state.matchIndex < 0 || state.matchIndex >= matches.length) { state.matchIndex = 0; }~,
    ~  matches[state.matchIndex].classList.add('active-match');~,
    ~  matches[state.matchIndex].scrollIntoView({ behavior: 'smooth', block: 'center' });~,
    ~  document.getElementById('search-match-index').textContent = state.matchIndex + 1;~,
    ~}~,
    ~function syncSearchMatchNav() {~,
    ~  var state = SPA_STATE.search; var viewer = document.getElementById('search-document-viewer'); var nav = document.getElementById('search-match-nav'); if (!state || !viewer || !nav) { return; }~,
    ~  var matches = viewer.querySelectorAll('mark');~,
    ~  if (!matches.length) { state.matchIndex = -1; nav.style.display = 'none'; document.getElementById('search-match-total').textContent = '0'; document.getElementById('search-match-index').textContent = '0'; return; }~,
    ~  if (state.matchIndex < 0 || state.matchIndex >= matches.length) { state.matchIndex = 0; }~,
    ~  nav.style.display = 'flex';~,
    ~  document.getElementById('search-match-total').textContent = matches.length;~,
    ~  highlightActiveSearchMatch();~,
    ~}~,
    ~function refreshSearchUI() {~,
    ~  var state = SPA_STATE.search; if (!state) { return; }~,
    ~  var filtered = getFilteredSearchResults(state);~,
    ~  if (!filtered.length) { state.selectedResultIndex = 0; state.matchIndex = 0; } else { var found = false; for (var i = 0; i < filtered.length; i++) { if (filtered[i].result_index === state.selectedResultIndex) { found = true; break; } } if (!found) { state.selectedResultIndex = 0; state.matchIndex = 0; } }~,
    ~  document.getElementById('search-category-filters').innerHTML = buildSearchFilterHtml(state, 'category');~,
    ~  document.getElementById('search-range-select').innerHTML = buildSearchDateOptionsHtml(state);~,
    ~  document.getElementById('search-results-sidebar').innerHTML = buildSearchSidebarHtml(state, filtered);~,
    ~  document.getElementById('search-document-viewer').innerHTML = buildSearchViewerHtml(state, filtered);~,
    ~  document.getElementById('search-visible-count').textContent = filtered.length + ' displayed';~,
    ~  document.getElementById('search-clear-btn').className = 'clear-btn' + (state.searchTerm ? ' visible' : '');~,
    ~  syncSearchMatchNav();~,
    ~}~,
    ~function setSearchCategory(code) { var state = SPA_STATE.search; if (!state) { return; } state.categoryCode = code; state.matchIndex = 0; refreshSearchUI(); }~,
    ~function setSearchRange(days) { var state = SPA_STATE.search; if (!state) { return; } state.rangeDays = Number(days || 0); state.matchIndex = 0; refreshSearchUI(); }~,
    ~function selectSearchResult(index) { var state = SPA_STATE.search; if (!state) { return; } state.selectedResultIndex = Number(index || 0); state.matchIndex = 0; refreshSearchUI(); }~,
    ~function stepSearchMatch(direction) { var state = SPA_STATE.search; var viewer = document.getElementById('search-document-viewer'); var matches = viewer ? viewer.querySelectorAll('mark') : []; if (!state || !matches.length) { return; } state.matchIndex = (state.matchIndex + direction + matches.length) % matches.length; highlightActiveSearchMatch(); }~,
    ~function clearSearchTerm() { var input = document.getElementById('search-filter-input'); var state = SPA_STATE.search; if (!input || !state) { return; } input.value = ''; state.searchTerm = ''; state.matchIndex = 0; refreshSearchUI(); input.focus(); }~,
    ~function onSearchFilterInput(value) { var state = SPA_STATE.search; if (!state) { return; } clearTimeout(state.inputTimer); state.inputTimer = setTimeout(function() { state.searchTerm = String(value || '').toLowerCase(); state.matchIndex = 0; refreshSearchUI(); }, 200); }~,
    ~/* NICU module */~,
    ~/* Antimicrobial module */~,
    ~function getMicroRoot(node) {~,
      ~  while (node && node.nodeType === 1) {~,
      ~    if (node.classList && node.classList.contains('module-micro')) { return node; }~,
    ~    node = node.parentNode;~,
    ~  }~,
    ~  return null;~,
    ~}~,
    ~function bindMicroStaticControls(root) {~,
    ~  if (!root || root.getAttribute('data-click-bound') === '1') { return; }~,
    ~  root.setAttribute('data-click-bound', '1');~,
    ~  root.addEventListener('click', function(event) {~,
    ~    var node = event.target;~,
    ~    while (node && node !== root) {~,
    ~      if (node.getAttribute && node.getAttribute('data-app')) { event.preventDefault(); handleAppLink(node); return; }~,
    ~      if (node.classList && node.classList.contains('med-trigger')) { toggleMicroMedication(node); return; }~,
    ~      node = node.parentNode;~,
    ~    }~,
    ~  });~,
    ~}~,
    ~function applyMicroMedicationFilter(root, medicationName) {~,
    ~  if (!root) { return; }~,
    ~  var items = root.querySelectorAll('.dimmable');~,
    ~  var triggers = root.querySelectorAll('.med-trigger');~,
    ~  var selected = String(medicationName || '');~,
    ~  var active = '';~,
    ~  var i;~,
    ~  for (i = 0; i < triggers.length; i++) {~,
    ~    if (triggers[i].getAttribute('data-med') === selected) {~,
    ~      triggers[i].classList.add('active-filter');~,
    ~      active = selected;~,
    ~    } else {~,
    ~      triggers[i].classList.remove('active-filter');~,
    ~    }~,
    ~  }~,
    ~  if (!active) {~,
    ~    for (i = 0; i < items.length; i++) { items[i].classList.remove('dimmed'); }~,
    ~  } else {~,
    ~    for (i = 0; i < items.length; i++) {~,
    ~      if (items[i].getAttribute('data-med') === active || items[i].classList.contains('always-on')) {~,
    ~        items[i].classList.remove('dimmed');~,
    ~      } else {~,
    ~        items[i].classList.add('dimmed');~,
    ~      }~,
    ~    }~,
    ~  }~,
    ~  if (SPA_STATE.micro) { SPA_STATE.micro.selectedMedication = active; }~,
    ~}~,
    ~function toggleMicroMedication(trigger) {~,
    ~  if (!trigger) { return; }~,
    ~  var root = getMicroRoot(trigger);~,
    ~  var medName = trigger.getAttribute('data-med') || '';~,
    ~  var isCurrentlyActive = trigger.classList.contains('active-filter');~,
    ~  applyMicroMedicationFilter(root, isCurrentlyActive ? '' : medName);~,
    ~}~,
    ~function bindMicroRowHover(root) {~,
    ~  if (!root) { return; }~,
    ~  var items = root.querySelectorAll('.dimmable[data-med]');~,
    ~  for (var i = 0; i < items.length; i++) {~,
    ~    items[i].addEventListener('mouseenter', function() {~,
    ~      var med = this.getAttribute('data-med');~,
    ~      var siblings;~,
    ~      var j;~,
    ~      if (!med) { return; }~,
    ~      siblings = root.querySelectorAll('.dimmable[data-med]');~,
    ~      for (j = 0; j < siblings.length; j++) { if (siblings[j].getAttribute('data-med') === med) { siblings[j].classList.add('row-hover'); } }~,
    ~    });~,
    ~    items[i].addEventListener('mouseleave', function() {~,
    ~      var med = this.getAttribute('data-med');~,
    ~      var siblings;~,
    ~      var j;~,
    ~      if (!med) { return; }~,
    ~      siblings = root.querySelectorAll('.dimmable[data-med]');~,
    ~      for (j = 0; j < siblings.length; j++) { if (siblings[j].getAttribute('data-med') === med) { siblings[j].classList.remove('row-hover'); } }~,
    ~    });~,
    ~  }~,
    ~}~,
    ~/* Tab lifecycle and bootstrap */~,
    ~function loadTab(tabId) {~,
    ~  var config = getTabConfig(tabId);~,
    ~  var target = getTabTarget(tabId);~,
    ~  if (!config || !target) { return; }~,
    ~  ACTIVE_TAB_ID = tabId;~,
    ~  setActiveButton(ACTIVE_TAB_ID);~,
    ~  setStatus('');~,
    ~  showLoading(config.label, target);~,
    ~  callCCL(tabId).then(function(data) { mountBackendUi(tabId, data, target); }).catch(function(error) { setStatus(error.message || 'Unable to load module.', 'error'); renderShellError(config.label, error.message || 'Unable to load module.', target); });~,
    ~}~,
    ~</script>~,
