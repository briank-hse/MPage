    ~}~,
    ~function hydrateSearchState(data) {~,
    ~  SPA_STATE.search = buildSearchState(data);~,
    ~  var input = document.getElementById('search-filter-input');~,
    ~  if (input) { input.placeholder = 'Search ' + SPA_STATE.search.results.length + ' chart documents...'; input.value = SPA_STATE.search.searchTerm || ''; }~,
    ~  refreshSearchUI();~,
    ~}~,
    ~function getSearchFilterCount(state, filter) {~,
    ~  var count = 0;~,
    ~  for (var i = 0; i < state.results.length; i++) { if (filter.filter_type === 'category') { if (filter.code === 'ALL' || String(state.results[i].category || '') === filter.code) { count = count + 1; } } else if (filter.filter_type === 'date_range') { if (matchesSearchRange(state.results[i], filter.days || 0)) { count = count + 1; } } }~,
    ~  return count;~,
    ~}~,
    ~function buildSearchFilterHtml(state, filterType) {~,
    ~  var html = [];~,
    ~  for (var i = 0; i < state.filters.length; i++) {~,
    ~    var filter = state.filters[i];~,
    ~    if (filter.filter_type !== filterType) { continue; }~,
    ~    var isActive = filterType === 'category' ? state.categoryCode === filter.code : Number(state.rangeDays || 0) === Number(filter.days || 0);~,
    ~    var action = filterType === 'category' ? ('setSearchCategory(' + JSON.stringify(String(filter.code || '')).replace(/"/g, '&quot;') + ')') : ('setSearchRange(' + Number(filter.days || 0) + ')');~,
    ~    html.push('<button class="filter-pill' + (isActive ? ' active' : '') + '" onclick="' + action + '">' + escapeHtml(filter.label || filter.code || '') + '</button>');~,
    ~  }~,
    ~  return html.join('');~,
    ~}~,
    ~function buildSearchDateOptionsHtml(state) {~,
    ~  var html = [];~,
    ~  for (var i = 0; i < state.filters.length; i++) {~,
    ~    var filter = state.filters[i];~,
    ~    if (filter.filter_type !== 'date_range') { continue; }~,
    ~    var selected = Number(state.rangeDays || 0) === Number(filter.days || 0) ? ' selected' : '';~,
    ~    html.push('<option value="' + Number(filter.days || 0) + '"' + selected + '>' + escapeHtml(filter.label || 'All Time') + '</option>');~,
    ~  }~,
    ~  return html.join('');~,
    ~}~,
    ~function getSearchPreviewText(text) {~,
    ~  return decodeTextEntities(String(text || '').replace(/<br\s*\/?>/gi, ' ').replace(/<[^>]+>/g, ' ')).replace(/\s+/g, ' ').trim();~,
    ~}~,
    ~function highlightSearchDocHtml(text, term) {~,
    ~  var html = String(text || '');~,
    ~  if (!term) { return html; }~,
    ~  var search = String(term).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');~,
    ~  return html.replace(new RegExp('(' + search + ')', 'gi'), '<mark>$1</mark>');~,
